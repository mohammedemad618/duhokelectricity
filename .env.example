# انسخ هذا الملف إلى .env.local واملأ القيم

# للتطوير المحلي استخدم: mongodb://127.0.0.1:27017 (مع: npm run db)
# للإنتاج استخدم رابط MongoDB Atlas
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=dohuk_electricity

# سرّ توقيع جلسات الدخول — استخدم قيمة عشوائية طويلة في الإنتاج
AUTH_SECRET=please-generate-a-long-random-secret
